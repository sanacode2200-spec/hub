{
  "name": "toolbox",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:hub": "turbo run dev --filter=hub",
    "dev:mov-to-mp4": "turbo run dev --filter=mov-to-mp4",
    "dev:portfolio": "turbo run dev --filter=sanacode-portfolio",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "packageManager": "npm@11.12.1",
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
