{
  "name": "toolbox",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:landing": "turbo run dev --filter=landing",
    "dev:qr-generator": "turbo run dev --filter=qr-generator",
    "dev:mov-to-mp4": "turbo run dev --filter=mov-to-mp4",
    "dev:ogp-generator": "turbo run dev --filter=ogp-generator",
    "dev:github-contributions": "turbo run dev --filter=github-contributions",
    "dev:portfolio": "turbo run dev --filter=sanacode-portfolio",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "packageManager": "npm@11.12.1",
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "sharp@0.34.5": true
  }
}
