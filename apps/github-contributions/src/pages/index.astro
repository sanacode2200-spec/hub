---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import ContributionsTool from "../components/ContributionsTool.svelte";
import HowItWorks from "../components/HowItWorks.astro";
import Features from "../components/Features.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="GitHub Contributions（草）ビジュアライザー 無料 | Toolbox"
  description="GitHubの公開プロフィールのContributionsグラフ（草）を年・月単位で表示。連続記録や合計数、最も活発だった日が一目でわかります。無料・ログイン・トークン不要。"
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: "GitHub Contributions ビジュアライザー",
      url: Astro.site?.href,
      description:
        "GitHubユーザーのContributionsグラフ（草）を月・年単位で表示。無料・ログイン・トークン不要。",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Any (runs in browser)",
      offers: { "@type": "Offer", price: "0", priceCurrency: "JPY" },
      inLanguage: "ja",
    })}
  />
  <main class="hub-shell" id="hub-shell">
    <div class="cursor-light" id="cursor-light"></div>
    <div class="grain-layer"></div>
    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>

    <div class="hub-frame">
      <Nav />

      <div class="gh-hero">
        <h1 class="gh-hero-title">GitHub Contributions <em>ビジュアライザー</em></h1>
        <p class="gh-hero-desc">
          GitHubの公開プロフィールの草（Contributionsグラフ）を年・月単位で表示。無料・ログイン不要・トークン不要。
        </p>
      </div>

      <ContributionsTool client:load />
      <HowItWorks />
      <Features />
      <CTA />
      <Footer />
    </div>
  </main>
</BaseLayout>

<script>
  const shell = document.getElementById("hub-shell");
  const cursorLight = document.getElementById("cursor-light");

  window.setTimeout(() => shell?.classList.add("is-loaded"), 120);

  window.addEventListener("mousemove", (event) => {
    if (!cursorLight) return;
    cursorLight.style.background = `radial-gradient(520px circle at ${event.clientX}px ${event.clientY}px, rgba(180,145,90,0.09), transparent 68%)`;
  });
</script>
