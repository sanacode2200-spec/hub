---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import GitTicker from "../components/GitTicker.astro";
import ToolsSection from "../components/ToolsSection.astro";
import Footer from "../components/Footer.astro";
import { tools } from "../data/tools";

const liveTools = tools.filter((tool) => tool.status === "live");
---

<BaseLayout
  title="無料のブラウザツール集 | Toolbox — 登録不要・データ保存なし"
  description="登録不要・広告なし・データ保存なしで使える無料ツール集。QRコード生成、MOV→MP4変換、OGP画像作成、GitHub Contributions（草）の可視化など、すべてブラウザだけで完結します。"
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          name: "Toolbox",
          url: Astro.site?.href,
          description: "登録不要・広告なし・データ保存なしの無料ブラウザツール集。",
          inLanguage: "ja",
        },
        {
          "@type": "ItemList",
          itemListElement: liveTools.map((tool, index) => ({
            "@type": "ListItem",
            position: index + 1,
            name: tool.name,
            description: tool.description,
            url: tool.url,
          })),
        },
      ],
    })}
  />
  <main class="hub-shell" id="hub-shell">
    <div class="cursor-light" id="cursor-light"></div>
    <div class="grain-layer"></div>
    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>

    <div class="hub-frame">
      <Nav />
      <Hero />
      <GitTicker />
      <ToolsSection />
      <Footer />
    </div>
  </main>
</BaseLayout>

<script>
  const shell = document.getElementById("hub-shell");
  const cursorLight = document.getElementById("cursor-light");

  window.setTimeout(() => shell?.classList.add("is-loaded"), 120);

  window.addEventListener("mousemove", (event) => {
    if (!cursorLight) return;
    cursorLight.style.background = `radial-gradient(520px circle at ${event.clientX}px ${event.clientY}px, rgba(180,145,90,0.09), transparent 68%)`;
  });
</script>
