---
---

<div class="glass-card" id="git-ticker-card" hidden>
  <div class="git-ticker">
    <span class="git-ticker-label">git log</span>
    <div class="git-ticker-track">
      <div class="git-ticker-inner" id="git-ticker-inner"></div>
    </div>
  </div>
</div>

<script>
  const REPOS = ["reflow", "hub", "clipo", "unblock"];
  const OWNER = "sanacode2200-spec";
  const PREFIX_RE =
    /^(feat|fix|chore|docs|style|refactor|test|build|ci|perf|revert)(\(.+?\))?!?:\s*/i;

  type Commit = { repo: string; message: string; date: string };
  type GithubCommit = {
    commit: { message: string; author: { date: string } };
  };

  async function loadGitActivity() {
    const results = await Promise.allSettled(
      REPOS.map((repo) =>
        fetch(`https://api.github.com/repos/${OWNER}/${repo}/commits?per_page=3`)
          .then((r) => r.json())
          .then((data: GithubCommit[]) =>
            data.slice(0, 3).map((c) => ({
              repo,
              message: c.commit.message.split("\n")[0].replace(PREFIX_RE, ""),
              date: c.commit.author.date,
            }))
          )
      )
    );

    const commits: Commit[] = results
      .filter((r): r is PromiseFulfilledResult<Commit[]> => r.status === "fulfilled")
      .flatMap((r) => r.value)
      .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
      .slice(0, 8);

    if (!commits.length) return;

    const card = document.getElementById("git-ticker-card");
    const inner = document.getElementById("git-ticker-inner");
    if (!card || !inner) return;

    const escapeHtml = (value: string) =>
      value.replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[char] ?? char);

    const items = [...commits, ...commits];
    inner.innerHTML = items
      .map(
        (c) => `
          <span class="git-ticker-item">
            <span class="git-ticker-repo">${escapeHtml(c.repo)}</span>
            <span class="git-ticker-msg">${escapeHtml(c.message)}</span>
            <span class="git-ticker-dot" aria-hidden="true">·</span>
          </span>
        `
      )
      .join("");

    card.hidden = false;
  }

  loadGitActivity();
</script>
