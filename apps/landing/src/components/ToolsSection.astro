---
import { categories, tools } from "../data/tools";
---

<section class="tool-section" aria-label="Tools">
  <div class="category-bar" id="category-bar" role="list" aria-label="Filter tools">
    {
      categories.map((category) => (
        <button
          type="button"
          class={`category-button ${category.id === "all" ? "is-active" : ""}`}
          data-category={category.id}
        >
          {category.label}
        </button>
      ))
    }
  </div>

  <div class="tool-layout glass-card">
    <div class="tool-list" id="tool-list">
      {
        tools.map((tool, index) => {
          const inner = (
            <>
              <span class="tool-row-index">{String(index + 1).padStart(2, "0")}</span>
              <span class="tool-row-main">
                <span class="tool-row-name">{tool.name}</span>
                <span class="tool-row-desc">{tool.description}</span>
              </span>
              <span class={`tool-status ${tool.status}`}>{tool.status}</span>
            </>
          );

          const dataAttrs = {
            "data-slug": tool.slug,
            "data-category": tool.category,
            "data-name": tool.name,
            "data-description": tool.description,
            "data-icon": tool.icon,
            "data-status": tool.status,
            "data-url": tool.url,
            "data-index": String(index),
          };

          return tool.status === "live" ? (
            <a href={tool.url} class="tool-row" {...dataAttrs}>
              {inner}
            </a>
          ) : (
            <div class="tool-row" {...dataAttrs}>
              {inner}
            </div>
          );
        })
      }
    </div>

    <aside class="tool-preview" id="tool-preview" aria-label="Tool preview"></aside>
  </div>
</section>

<script define:vars={{ tools: tools.map(({ slug, name, description, icon, status, url }) => ({ slug, name, description, icon, status, url })) }}>
  const categoryBar = document.getElementById("category-bar");
  const toolList = document.getElementById("tool-list");
  const preview = document.getElementById("tool-preview");
  const rows = Array.from(toolList?.querySelectorAll(".tool-row") ?? []);

  function renderPreview(tool) {
    if (!preview) return;
    preview.innerHTML = `
      <span class="preview-icon" aria-hidden="true">${tool.icon}</span>
      <span class="tool-status ${tool.status}">${tool.status}</span>
      <h2>${tool.name}</h2>
      <p>${tool.description}</p>
      ${
        tool.status === "live"
          ? `<a href="${tool.url}" class="preview-action">Open tool</a>`
          : `<span class="preview-action disabled">Coming soon</span>`
      }
    `;
  }

  function selectTool(slug) {
    rows.forEach((row) => row.classList.toggle("is-selected", row.dataset.slug === slug));
    const tool = tools.find((t) => t.slug === slug);
    if (tool) renderPreview(tool);
  }

  function firstVisibleSlug() {
    const visible = rows.find((row) => !row.classList.contains("is-hidden"));
    return visible?.dataset.slug ?? rows[0]?.dataset.slug;
  }

  // Category filtering
  categoryBar?.addEventListener("click", (event) => {
    const button = event.target.closest(".category-button");
    if (!button) return;

    categoryBar.querySelectorAll(".category-button").forEach((b) => b.classList.remove("is-active"));
    button.classList.add("is-active");

    const category = button.dataset.category;
    rows.forEach((row) => {
      const matches = category === "all" || row.dataset.category === category;
      row.classList.toggle("is-hidden", !matches);
    });

    const slug = firstVisibleSlug();
    if (slug) selectTool(slug);
  });

  // Row selection (hover/focus mirrors the original preview-on-hover behaviour)
  rows.forEach((row) => {
    row.addEventListener("mouseenter", () => selectTool(row.dataset.slug));
    row.addEventListener("focus", () => selectTool(row.dataset.slug));
  });

  // Stagger fade-in on scroll into view
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const row = entry.target;
          const index = Number(row.dataset.index ?? 0);
          row.style.transitionDelay = `${index * 70}ms`;
          row.classList.add("is-visible");
          observer.unobserve(row);
        }
      });
    },
    { threshold: 0.12 }
  );
  rows.forEach((row) => observer.observe(row));

  // Initial preview = first tool
  if (tools[0]) selectTool(tools[0].slug);
</script>
