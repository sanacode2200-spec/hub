---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import QrTool from "../components/QrTool.svelte";
import HowItWorks from "../components/HowItWorks.astro";
import Features from "../components/Features.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="QR Generator | Toolbox"
  description="URLや連絡先、Wi-Fi情報などから無料でQRコードを作成。登録不要・スキャン回数の上限なし。色やドットの形、ロゴを自由にカスタマイズしてSVGまたはPNGで書き出せます。"
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: "QRコードジェネレーター",
      url: Astro.site?.href,
      description:
        "URLや連絡先などのQRコードを無料で作成。登録不要・スキャン回数の上限なし。",
      applicationCategory: "UtilitiesApplication",
      operatingSystem: "Any (runs in browser)",
      offers: { "@type": "Offer", price: "0", priceCurrency: "JPY" },
      inLanguage: "ja",
    })}
  />
  <main class="hub-shell" id="hub-shell">
    <div class="cursor-light" id="cursor-light"></div>
    <div class="grain-layer"></div>
    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>

    <div class="hub-frame">
      <Nav />

      <div class="qr-hero">
        <h1 class="qr-hero-title">Free QR Code <em>Generator</em></h1>
        <p class="qr-hero-desc">
          URL・連絡先・Wi-Fiなど、用途に合わせたQRコードを作成。登録不要・スキャン回数の上限なし。SVGまたはPNGで書き出せます。
        </p>
      </div>

      <QrTool client:load />
      <HowItWorks />
      <Features />
      <CTA />
      <Footer />
    </div>
  </main>
</BaseLayout>

<script>
  const shell = document.getElementById("hub-shell");
  const cursorLight = document.getElementById("cursor-light");

  window.setTimeout(() => shell?.classList.add("is-loaded"), 120);

  window.addEventListener("mousemove", (event) => {
    if (!cursorLight) return;
    cursorLight.style.background = `radial-gradient(520px circle at ${event.clientX}px ${event.clientY}px, rgba(180,145,90,0.09), transparent 68%)`;
  });
</script>
