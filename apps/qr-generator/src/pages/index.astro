---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import QrTool from "../components/QrTool.svelte";
import HowItWorks from "../components/HowItWorks.astro";
import Features from "../components/Features.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Free QR Code Generator — ToolBox"
  description="Generate custom QR codes for links, profiles, and contact info. Free, no signup, no scan limits. Customize colors, dot style, and logo, then export SVG or PNG."
>
  <main class="hub-shell" id="hub-shell">
    <div class="cursor-light" id="cursor-light"></div>
    <div class="grain-layer"></div>
    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>

    <div class="hub-frame">
      <Nav />
      <QrTool client:load />
      <HowItWorks />
      <Features />
      <CTA />
      <Footer />
    </div>
  </main>
</BaseLayout>

<script>
  const shell = document.getElementById("hub-shell");
  const cursorLight = document.getElementById("cursor-light");

  window.setTimeout(() => shell?.classList.add("is-loaded"), 120);

  window.addEventListener("mousemove", (event) => {
    if (!cursorLight) return;
    cursorLight.style.background = `radial-gradient(520px circle at ${event.clientX}px ${event.clientY}px, rgba(180,145,90,0.09), transparent 68%)`;
  });
</script>
