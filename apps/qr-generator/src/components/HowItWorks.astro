---
const steps = [
  {
    step: "01",
    title: "コンテンツを入力",
    desc: "URL、プロフィールリンク、メッセージ、メール、電話番号などを入力します。",
  },
  {
    step: "02",
    title: "デザインをカスタマイズ",
    desc: "誤り訂正レベル、ドットの形、カラー、ロゴを自由に設定できます。",
  },
  {
    step: "03",
    title: "書き出してスキャン確認",
    desc: "SVGまたは高解像度PNGをダウンロードし、カメラでスキャンして確認できます。",
  },
];
---

<section aria-label="How it works">
  <h2 class="section-heading">使い方</h2>
  <div class="info-grid">
    {
      steps.map((item) => (
        <div class="info-card">
          <div class="step">{item.step}</div>
          <h3 class="title">{item.title}</h3>
          <div class="desc">{item.desc}</div>
        </div>
      ))
    }
  </div>
</section>
