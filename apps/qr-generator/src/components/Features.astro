---
const features = [
  "∞  スキャン回数の上限なし",
  "✓  SVG・PNGどちらも無料",
  "📷  カメラでスキャン確認",
  "5種類のカラーパレット + カスタム",
  "🖼  ロゴ・アイコンの埋め込み",
  "Square or round dot styles",
];
---

<section aria-label="Features">
  <h2 class="section-heading">特徴</h2>
  <div class="feature-grid">
    {features.map((feature) => <div class="feature-item">{feature}</div>)}
  </div>
</section>
