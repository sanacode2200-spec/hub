---
const features = [
  "∞  No scan limits, ever",
  "✓  SVG & PNG, both free",
  "📷  Built-in camera scan test",
  "5 color palettes + custom",
  "🖼  Logo / icon embedding",
  "Square or round dot styles",
];
---

<section aria-label="Features">
  <div class="feature-grid">
    {features.map((feature) => <div class="feature-item">{feature}</div>)}
  </div>
</section>
