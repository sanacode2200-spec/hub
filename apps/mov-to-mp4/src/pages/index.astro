---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import ConverterTool from "../components/ConverterTool.svelte";
import HowItWorks from "../components/HowItWorks.astro";
import Features from "../components/Features.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="MOV→MP4 | Toolbox"
  description="iPhoneで撮影したMOV動画をブラウザ上でMP4に変換。無料・登録不要・アップロード不要・ファイルサイズの上限なし。"
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: "MOV→MP4コンバーター",
      url: Astro.site?.href,
      description:
        "iPhoneのMOV動画をブラウザでMP4に変換。無料・登録不要・アップロード不要・サイズ上限なし。",
      applicationCategory: "MultimediaApplication",
      operatingSystem: "Any (runs in browser)",
      offers: { "@type": "Offer", price: "0", priceCurrency: "JPY" },
      inLanguage: "ja",
    })}
  />
  <main class="hub-shell" id="hub-shell">
    <div class="cursor-light" id="cursor-light"></div>
    <div class="grain-layer"></div>
    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>

    <div class="hub-frame">
      <Nav />

      <div class="mov-hero">
        <h1 class="mov-hero-title">MOV / WebM to <em>MP4</em>, instantly</h1>
        <p class="mov-hero-desc">
          iPhoneのMOV動画やWebM動画をブラウザだけでMP4に変換。アップロードも登録も不要、ファイルサイズの上限もありません。
        </p>
      </div>

      <ConverterTool client:load />
      <HowItWorks />
      <Features />
      <CTA />
      <Footer />
    </div>
  </main>
</BaseLayout>

<script>
  const shell = document.getElementById("hub-shell");
  const cursorLight = document.getElementById("cursor-light");

  window.setTimeout(() => shell?.classList.add("is-loaded"), 120);

  window.addEventListener("mousemove", (event) => {
    if (!cursorLight) return;
    cursorLight.style.background = `radial-gradient(520px circle at ${event.clientX}px ${event.clientY}px, rgba(180,145,90,0.09), transparent 68%)`;
  });
</script>
