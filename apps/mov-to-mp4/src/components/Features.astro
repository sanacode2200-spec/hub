---
const features = [
  "🔒  Files never leave your browser",
  "⚡  Fast remuxing, no re-encoding",
  "🆓  Free, with no signup",
  "📵  No ads or tracking",
  "♾️  No file size limit",
  "📱  Built for iPhone MOV videos",
];
---

<section aria-label="Features">
  <div class="feature-grid">
    {features.map((feature) => <div class="feature-item">{feature}</div>)}
  </div>
</section>
