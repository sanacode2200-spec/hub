---
const features = [
  "🔒  ファイルはブラウザの外に出ません",
  "⚡  再エンコードなしで高速変換",
  "🆓  無料・登録不要",
  "📵  広告・トラッキングなし",
  "♾️  ファイルサイズの上限なし",
  "📱  iPhoneのMOV動画に対応",
];
---

<section aria-label="Features">
  <h2 class="section-heading">特徴</h2>
  <div class="feature-grid">
    {features.map((feature) => <div class="feature-item">{feature}</div>)}
  </div>
</section>
