---
const features = [
  "1200x630 — OGP標準サイズ",
  "↓  PNG・@2x書き出し",
  "🎨  単色・グラデーション背景",
  "Serif / Mono / Sans",
  "⚡  リアルタイムプレビュー",
  "登録不要・ブラウザで完結",
];
---

<section aria-label="Features">
  <h2 class="section-heading">特徴</h2>
  <div class="feature-grid">
    {features.map((feature) => <div class="feature-item">{feature}</div>)}
  </div>
</section>
