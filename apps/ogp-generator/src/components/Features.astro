---
const features = [
  "1200x630 — exact OG size",
  "↓  PNG & @2x export",
  "🎨  Solid or gradient backgrounds",
  "Serif / Mono / Sans",
  "⚡  Instant live preview",
  "No signup, runs in your browser",
];
---

<section aria-label="Features">
  <div class="feature-grid">
    {features.map((feature) => <div class="feature-item">{feature}</div>)}
  </div>
</section>
