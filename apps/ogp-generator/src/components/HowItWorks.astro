---
const steps = [
  {
    step: "01",
    title: "テキストを入力",
    desc: "ラベル・見出し・短い説明文を入力します。",
  },
  {
    step: "02",
    title: "デザインを調整",
    desc: "テンプレートを選び、フォントや背景の色・グラデーションを設定します。",
  },
  {
    step: "03",
    title: "1200x630のPNGを書き出し",
    desc: "OGP標準サイズでダウンロード、または高解像度の@2xで書き出せます。",
  },
];
---

<section aria-label="How it works">
  <h2 class="section-heading">使い方</h2>
  <div class="info-grid">
    {
      steps.map((item) => (
        <div class="info-card">
          <div class="step">{item.step}</div>
          <h3 class="title">{item.title}</h3>
          <div class="desc">{item.desc}</div>
        </div>
      ))
    }
  </div>
</section>
