---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import OgpTool from "../components/OgpTool.svelte";
import HowItWorks from "../components/HowItWorks.astro";
import Features from "../components/Features.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="OGP画像作成 無料 - 1200×630のSNSシェア画像 | Toolbox"
  description="OGP・Twitterカードのシェア画像を1200×630のジャストサイズで作成。無料・登録不要。テンプレートやフォント、グラデーションでデザインしてPNG/@2xで書き出せます。"
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: "OGP画像ジェネレーター",
      url: Astro.site?.href,
      description:
        "OGP・Twitterシェア画像を1200×630のジャストサイズで作成。無料・登録不要、ブラウザだけで完結。",
      applicationCategory: "DesignApplication",
      operatingSystem: "Any (runs in browser)",
      offers: { "@type": "Offer", price: "0", priceCurrency: "JPY" },
      inLanguage: "ja",
    })}
  />
  <main class="hub-shell" id="hub-shell">
    <div class="cursor-light" id="cursor-light"></div>
    <div class="grain-layer"></div>
    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>

    <div class="hub-frame">
      <Nav />

      <div class="ogp-hero">
        <h1 class="ogp-hero-title">無料のOGP画像<em>ジェネレーター</em></h1>
        <p class="ogp-hero-desc">
          OGP・Twitterのシェア画像を1200×630のジャストサイズで作成。登録不要、すべてブラウザ内で完結します。
        </p>
      </div>

      <OgpTool client:load />
      <HowItWorks />
      <Features />
      <CTA />
      <Footer />
    </div>
  </main>
</BaseLayout>

<script>
  const shell = document.getElementById("hub-shell");
  const cursorLight = document.getElementById("cursor-light");

  window.setTimeout(() => shell?.classList.add("is-loaded"), 120);

  window.addEventListener("mousemove", (event) => {
    if (!cursorLight) return;
    cursorLight.style.background = `radial-gradient(520px circle at ${event.clientX}px ${event.clientY}px, rgba(180,145,90,0.09), transparent 68%)`;
  });
</script>
